<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BcHelpArticleMapper">

    <resultMap type="BcHelpArticle" id="BcHelpArticleResult">
        <id     property="articleId"      column="article_id" />
        <result property="categoryId"     column="category_id" />
        <result property="categoryName"   column="category_name" />
        <result property="question"       column="question" />
        <result property="answer"         column="answer" />
        <result property="keywords"        column="keywords" />
        <result property="isHot"          column="is_hot" />
        <result property="isRecommend"    column="is_recommend" />
        <result property="viewCount"      column="view_count" />
        <result property="sortNum"        column="sort_num" />
        <result property="status"         column="status" />
        <result property="createBy"       column="create_by" />
        <result property="createTime"     column="create_time" />
        <result property="updateBy"       column="update_by" />
        <result property="updateTime"     column="update_time" />
        <result property="remark"          column="remark" />
    </resultMap>

    <sql id="selectArticleVo">
        select a.article_id, a.category_id, c.category_name, a.question, a.answer,
               a.keywords, a.is_hot, a.is_recommend, a.view_count, a.sort_num,
               a.status, a.create_by, a.create_time, a.update_by, a.update_time, a.remark
        from bc_help_article a
        left join bc_help_category c on a.category_id = c.category_id
    </sql>

    <select id="selectHelpArticleList" parameterType="BcHelpArticle" resultMap="BcHelpArticleResult">
        <include refid="selectArticleVo"/>
        <where>
            <if test="categoryId != null">AND a.category_id = #{categoryId}</if>
            <if test="question != null and question != ''">
                AND a.question like concat('%', #{question}, '%')
            </if>
            <if test="keywords != null and keywords != ''">
                AND a.keywords like concat('%', #{keywords}, '%')
            </if>
            <if test="isHot != null and isHot != ''">AND a.is_hot = #{isHot}</if>
            <if test="isRecommend != null and isRecommend != ''">AND a.is_recommend = #{isRecommend}</if>
            <if test="status != null and status != ''">AND a.status = #{status}</if>
        </where>
        order by a.sort_num
    </select>

    <select id="selectHelpArticleAll" resultMap="BcHelpArticleResult">
        <include refid="selectArticleVo"/>
        where a.status = '0'
        order by a.sort_num
    </select>

    <select id="selectHotArticleList" parameterType="int" resultMap="BcHelpArticleResult">
        <include refid="selectArticleVo"/>
        where a.status = '0'
        order by a.view_count desc, a.sort_num
        limit #{limit}
    </select>

    <select id="fuzzySearchArticles" parameterType="String" resultMap="BcHelpArticleResult">
        <include refid="selectArticleVo"/>
        where a.status = '0'
          and (
            a.question like concat('%', #{keyword}, '%')
            or a.keywords like concat('%', #{keyword}, '%')
            or a.answer like concat('%', #{keyword}, '%')
          )
        order by a.view_count desc, a.sort_num
        limit 20
    </select>

    <select id="selectHelpArticleById" parameterType="Long" resultMap="BcHelpArticleResult">
        <include refid="selectArticleVo"/>
        where a.article_id = #{articleId}
    </select>

    <insert id="insertHelpArticle" parameterType="BcHelpArticle" useGeneratedKeys="true" keyProperty="articleId">
        insert into bc_help_article(
            <if test="articleId != null and articleId != 0">article_id,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="question != null and question != ''">question,</if>
            <if test="answer != null">answer,</if>
            <if test="keywords != null">keywords,</if>
            <if test="isHot != null and isHot != ''">is_hot,</if>
            <if test="isRecommend != null and isRecommend != ''">is_recommend,</if>
            <if test="viewCount != null">view_count,</if>
            <if test="sortNum != null">sort_num,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="articleId != null and articleId != 0">#{articleId},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="question != null and question != ''">#{question},</if>
            <if test="answer != null">#{answer},</if>
            <if test="keywords != null">#{keywords},</if>
            <if test="isHot != null and isHot != ''">#{isHot},</if>
            <if test="isRecommend != null and isRecommend != ''">#{isRecommend},</if>
            <if test="viewCount != null">#{viewCount},</if>
            <if test="sortNum != null">#{sortNum},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateHelpArticle" parameterType="BcHelpArticle">
        update bc_help_article
        <set>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="question != null and question != ''">question = #{question},</if>
            <if test="answer != null">answer = #{answer},</if>
            <if test="keywords != null">keywords = #{keywords},</if>
            <if test="isHot != null and isHot != ''">is_hot = #{isHot},</if>
            <if test="isRecommend != null and isRecommend != ''">is_recommend = #{isRecommend},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            <if test="sortNum != null">sort_num = #{sortNum},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where article_id = #{articleId}
    </update>

    <update id="incrementViewCount" parameterType="Long">
        update bc_help_article set view_count = view_count + 1 where article_id = #{articleId}
    </update>

    <delete id="deleteHelpArticleByIds" parameterType="Long">
        delete from bc_help_article where article_id in
        <foreach collection="array" item="articleId" open="(" separator="," close=")">
            #{articleId}
        </foreach>
    </delete>

    <select id="countByCategoryId" parameterType="Long" resultType="int">
        select count(1) from bc_help_article where category_id = #{categoryId}
    </select>

</mapper>
