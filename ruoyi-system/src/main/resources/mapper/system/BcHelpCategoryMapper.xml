<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BcHelpCategoryMapper">

    <resultMap type="BcHelpCategory" id="BcHelpCategoryResult">
        <id     property="categoryId"    column="category_id" />
        <result property="categoryName"  column="category_name" />
        <result property="categoryCode"  column="category_code" />
        <result property="parentId"      column="parent_id" />
        <result property="ancestors"     column="ancestors" />
        <result property="sortNum"       column="sort_num" />
        <result property="icon"          column="icon" />
        <result property="status"        column="status" />
        <result property="createBy"      column="create_by" />
        <result property="createTime"    column="create_time" />
        <result property="updateBy"      column="update_by" />
        <result property="updateTime"    column="update_time" />
        <result property="remark"         column="remark" />
    </resultMap>

    <sql id="selectCategoryVo">
        select category_id, category_name, category_code, parent_id, ancestors, sort_num, icon, status, create_by, create_time, update_by, update_time, remark
        from bc_help_category
    </sql>

    <select id="selectHelpCategoryList" parameterType="BcHelpCategory" resultMap="BcHelpCategoryResult">
        <include refid="selectCategoryVo"/>
        <where>
            <if test="categoryName != null and categoryName != ''">
                AND category_name like concat('%', #{categoryName}, '%')
            </if>
            <if test="categoryCode != null and categoryCode != ''">
                AND category_code like concat('%', #{categoryCode}, '%')
            </if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by sort_num
    </select>

    <select id="selectHelpCategoryAll" resultMap="BcHelpCategoryResult">
        <include refid="selectCategoryVo"/>
        where status = '0'
        order by sort_num
    </select>

    <select id="selectHelpCategoryById" parameterType="Long" resultMap="BcHelpCategoryResult">
        <include refid="selectCategoryVo"/>
        where category_id = #{categoryId}
    </select>

    <select id="selectHelpCategoryByCode" parameterType="String" resultMap="BcHelpCategoryResult">
        <include refid="selectCategoryVo"/>
        where category_code = #{categoryCode} limit 1
    </select>

    <select id="checkCategoryCodeUnique" parameterType="String" resultMap="BcHelpCategoryResult">
        <include refid="selectCategoryVo"/>
        where category_code = #{categoryCode} limit 1
    </select>

    <select id="selectChildrenCountById" parameterType="Long" resultType="int">
        select count(1) from bc_help_category where parent_id = #{categoryId}
    </select>

    <insert id="insertHelpCategory" parameterType="BcHelpCategory" useGeneratedKeys="true" keyProperty="categoryId">
        insert into bc_help_category(
            <if test="categoryId != null and categoryId != 0">category_id,</if>
            <if test="categoryName != null and categoryName != ''">category_name,</if>
            <if test="categoryCode != null and categoryCode != ''">category_code,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="ancestors != null">ancestors,</if>
            <if test="sortNum != null">sort_num,</if>
            <if test="icon != null">icon,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="categoryId != null and categoryId != 0">#{categoryId},</if>
            <if test="categoryName != null and categoryName != ''">#{categoryName},</if>
            <if test="categoryCode != null and categoryCode != ''">#{categoryCode},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="ancestors != null">#{ancestors},</if>
            <if test="sortNum != null">#{sortNum},</if>
            <if test="icon != null">#{icon},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateHelpCategory" parameterType="BcHelpCategory">
        update bc_help_category
        <set>
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="categoryCode != null and categoryCode != ''">category_code = #{categoryCode},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="ancestors != null">ancestors = #{ancestors},</if>
            <if test="sortNum != null">sort_num = #{sortNum},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where category_id = #{categoryId}
    </update>

    <delete id="deleteHelpCategoryByIds" parameterType="Long">
        delete from bc_help_category where category_id in
        <foreach collection="array" item="categoryId" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </delete>

</mapper>
