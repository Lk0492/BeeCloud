<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BcHelpViewLogMapper">

    <insert id="insertViewLog" parameterType="BcHelpViewLog" useGeneratedKeys="true" keyProperty="logId">
        insert into bc_help_view_log(
            <if test="logId != null and logId != 0">log_id,</if>
            <if test="articleId != null">article_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="userName != null">user_name,</if>
            <if test="ipAddr != null">ip_addr,</if>
            create_time
        )values(
            <if test="logId != null and logId != 0">#{logId},</if>
            <if test="articleId != null">#{articleId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="userName != null">#{userName},</if>
            <if test="ipAddr != null">#{ipAddr},</if>
            sysdate()
        )
    </insert>

</mapper>
